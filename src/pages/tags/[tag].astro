---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tagSet = [...new Set(posts.flatMap(p => p.data.tags ?? []))];
  const categorySet = [...new Set(posts.map(p => p.data.category).filter(Boolean) as string[])];
  const allKeys = [...new Set([...tagSet, ...categorySet])];

  return allKeys.map(tag => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter(p => p.data.tags?.includes(tag) || p.data.category === tag)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<BaseLayout title={`タグ: ${tag}`}>
  <div class="tag-page-header">
    <a href={`${base}tags/`} class="back-link">← タグ一覧</a>
    <h1 class="page-heading">タグ: <span class="tag">{tag}</span></h1>
    <p class="tag-page-count">{posts.length}件の記事</p>
  </div>

  <ul class="post-list" role="list">
    {posts.map(post => {
      const url = `${base}blog/${post.slug}/`;
      const date = post.data.pubDate.toLocaleDateString('ja-JP', {
        year: 'numeric', month: 'long', day: 'numeric',
      });
      return (
        <li>
          <a href={url} class="post-card" style="display:block;text-decoration:none;">
            <h2 class="post-card-title">{post.data.title}</h2>
            <p class="post-card-desc">{post.data.description}</p>
            <div class="post-card-meta">
              <time class="post-date" datetime={post.data.pubDate.toISOString()}>{date}</time>
              {post.data.tags?.map(t => <span class="tag">{t}</span>)}
            </div>
          </a>
        </li>
      );
    })}
  </ul>
</BaseLayout>
